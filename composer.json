{
    "name": "microscrap/phpdafruit-gfx",
    "description": "AdafruitGFX-like Rendering Package for the ScrapyardIO Framework",
    "license": "MIT",
    "homepage": "https://scrapyard-io.projectsaturnstudios.com",
    "version": "0.4.1",
    "authors": [
        {
            "name": "Angel Gonzalez",
            "email": "angel@projectsaturnstudios.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "scrapyard-io/nuts-and-bolts": "^0.4.1",
        "scrapyard-io/reality-interface": "^0.4.1"
    },
    "require-dev": {
        "pestphp/pest": "^4"
    },
    "suggest": {
        "ext-gd": "Required only for drawImageFromFile() and drawImageDithered() to decode JPEG/PNG/GIF/WebP/BMP files. Raw pixel data via drawBitmap()/drawColorMap()/ditherFloydSteinberg() works without it."
    },
    "autoload": {
        "psr-4": {
            "Microscrap\\GFX\\PhpdaFruit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DeptOfScrapyardRobotics\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev"
}
